# metrics/mitigation.py
import pandas as pd
from sklearn.linear_model import LogisticRegression
from sklearn.preprocessing import StandardScaler
from sklearn.pipeline import Pipeline

def train_baseline_model(X: pd.DataFrame, y: pd.Series):
    pipe = Pipeline(
        steps=[
            ("scaler", StandardScaler(with_mean=False)),
            ("clf", LogisticRegression(max_iter=1000)),
        ]
    )
    pipe.fit(X, y)
    return pipe

def reweight_samples(X, y, sensitive):
    """
    Return sample weights to reduce imbalance across sensitive groups.
    """
    df = pd.concat({"y": y, "s": sensitive}, axis=1)
    group_counts = df.groupby(["s", "y"]).size()
    inv_freq = 1.0 / group_counts
    weights = df.apply(lambda row: inv_freq.loc[row["s"], row["y"]], axis=1)
    return weights
